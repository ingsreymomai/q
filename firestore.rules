rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: history
    // Fields: id, title, content, timestamp, uid
    //
    // Collection: customExerciseTypes
    // Fields: id, name, category, uid
    //
    // Collection: customDesigns
    // Fields: id, name, type, html, css, uid
    //
    // Collection: users
    // Fields: schoolName, schoolAddress, logoData, activeFont, uid
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidHistory(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 1000000 &&
             data.timestamp is number &&
             data.uid == request.auth.uid;
    }

    function isValidExerciseType(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category in ['Grammar', 'Reading', 'Vocabulary', 'Mixed'] &&
             data.uid == request.auth.uid;
    }

    function isValidDesign(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.type is string &&
             data.html is string && data.html.size() < 50000 &&
             (!('css' in data) || (data.css is string && data.css.size() < 50000)) &&
             data.uid == request.auth.uid;
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             (!('schoolName' in data) || (data.schoolName is string && data.schoolName.size() < 200)) &&
             (!('schoolAddress' in data) || (data.schoolAddress is string && data.schoolAddress.size() < 500)) &&
             (!('logoData' in data) || (data.logoData is string && data.logoData.size() < 2000000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /history/{historyId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidHistory(request.resource.data);
      allow update: if isDocOwner() && isValidHistory(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /customExerciseTypes/{typeId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidExerciseType(request.resource.data);
      allow update: if isDocOwner() && isValidExerciseType(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /customDesigns/{designId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidDesign(request.resource.data);
      allow update: if isDocOwner() && isValidDesign(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified();
      allow delete: if isOwner(userId);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
